{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "^(startup|resume|compact|clear)$",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"%STEADYAGENT_HOME%\\tools\\hooks\\agent-hook-context.ps1\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"%STEADYAGENT_HOME%\\tools\\hooks\\agent-hook-prompt-reminder.ps1\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^(Bash|PowerShell|shell_command|functions[.]shell_command|multi_tool_use[.]parallel)$",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"%STEADYAGENT_HOME%\\tools\\hooks\\agent-hook-command-guard.ps1\""
          }
        ]
      },
      {
        "matcher": "^(apply_patch|Edit|Write|MultiEdit|functions[.]apply_patch|multi_tool_use[.]parallel)$",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"%STEADYAGENT_HOME%\\tools\\hooks\\agent-hook-file-guard.ps1\""
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "^(Bash|PowerShell|shell_command|functions[.]shell_command|multi_tool_use[.]parallel)$",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"%STEADYAGENT_HOME%\\tools\\hooks\\agent-hook-permission-guard.ps1\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^(Bash|PowerShell|shell_command|functions[.]shell_command|multi_tool_use[.]parallel|apply_patch|Edit|Write|MultiEdit|functions[.]apply_patch)$",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"%STEADYAGENT_HOME%\\tools\\hooks\\agent-hook-posttool-audit.ps1\""
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "^manual$",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"%STEADYAGENT_HOME%\\tools\\hooks\\agent-hook-precompact.ps1\""
          }
        ]
      },
      {
        "matcher": "^auto$",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"%STEADYAGENT_HOME%\\tools\\hooks\\agent-hook-precompact.ps1\""
          }
        ]
      }
    ]
  }
}
